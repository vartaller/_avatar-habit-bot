# Copy to .env and fill in the values

# Telegram bot token from @BotFather
BOT_TOKEN=123456789:AABBCCDDEEFFaabbccddeeff

# Your Telegram numeric user ID (get it from @userinfobot)
OWNER_ID=123456789

# PostgreSQL connection string (Supabase → Settings → Database → Connection string)
DATABASE_URL=postgresql://postgres:password@db.xxxx.supabase.co:5432/postgres

# Optional: time to send the daily reminder (24h format, UTC)
REMINDER_HOUR=23
REMINDER_MINUTE=0
